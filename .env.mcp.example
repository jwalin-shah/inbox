INBOX_SERVER_URL=http://127.0.0.1:9849

# Set this if you enable auth on the private inbox server.
INBOX_SERVER_TOKEN=

# Set this before exposing the MCP server publicly.
INBOX_MCP_TOKEN=replace-with-a-long-random-token

